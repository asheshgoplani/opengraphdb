{
  "name": "@opengraphdb/mcp",
  "version": "0.1.0",
  "description": "MCP server for OpenGraphDB — connect any AI agent to your graph database",
  "type": "module",
  "bin": {
    "opengraphdb-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "opengraphdb", "graph-database", "cypher", "ai", "knowledge-graph", "claude", "copilot", "cursor"],
  "author": "OpenGraphDB Contributors",
  "license": "MIT",
  "homepage": "https://github.com/openGraphDB/openGraphDB/tree/main/mcp",
  "bugs": "https://github.com/openGraphDB/openGraphDB/issues",
  "engines": { "node": ">=18" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/openGraphDB/openGraphDB",
    "directory": "mcp"
  }
}
